{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["jest"]
  },
  "include": ["server.ts", "routes/**/*.ts", "services/**/*.ts", "middleware/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
