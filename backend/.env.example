# Backend environment configuration template
# Copy this to .env.development or .env.production and update values

PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# CORS Configuration
# For development: http://localhost:5173 (Vite default port)
# For production: https://yourdomain.com
CORS_ORIGIN=http://localhost:5173

# File upload limits
MAX_FILE_SIZE=5242880
ALLOWED_MIME_TYPES=text/plain
MAX_BODY_SIZE=10mb

# Static files path
STATIC_PATH=./frontend/dist
