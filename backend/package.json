{
  "name": "vehicle-selector-backend",
  "version": "1.0.0",
  "description": "Simple Express server with vanilla HTML/JS for vehicle selection and logbook upload",
  "main": "dist/server.js",
  "scripts": {
    "start": "ts-node server.ts",
    "dev": "ts-node server.ts",
    "build": "tsc",
    "test": "jest",
    "pm2:start": "npm run build && pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 delete vehicle-selector-backend || true",
    "pm2:restart": "pm2 restart vehicle-selector-backend || npm run pm2:start",
    "pm2:logs": "pm2 logs vehicle-selector-backend --lines 100"
  },
  "dependencies": {
    "express": "^5.2.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "pm2": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/?(*.)+(spec|test).[tj]s?(x)"],
    "testPathIgnorePatterns": ["/node_modules/", "/dist/"]
  }
}
